 enum class Key : int {
     // Driving actions
     ACCELERATE,
@@ -55,6 +57,17 @@ class Input {
                event.key.code == get(action);
     }
     static inline bool held(const Key action) {
+        // CAN-driven driving controls when an IPC source is active.
+        if (IpcInput::g_active.load()) {
+            switch (action) {
+                case Key::TURN_LEFT:  if (IpcInput::turnLeftHeld())  return true; break;
+                case Key::TURN_RIGHT: if (IpcInput::turnRightHeld()) return true; break;
+                case Key::ACCELERATE: if (IpcInput::acceleratHeld()) return true; break;
+                case Key::BRAKE:      if (IpcInput::brakeHeld())     return true; break;
+                case Key::DRIFT:      if (IpcInput::driftHeld())     return true; break;
+                default: break;
+            }
+        }
         return sf::Keyboard::isKeyPressed(get(action)) &&
                instance.gameWindow->hasFocus();
     }
